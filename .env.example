# =============================================================================
# IronKey Backend — Variables de entorno
# Copia este archivo como .env y completa los valores antes de desplegar
# NUNCA subas el .env real al repositorio
# =============================================================================

# -----------------------------------------------------------------------------
# Base de datos PostgreSQL
# -----------------------------------------------------------------------------
DB_NAME=ironkey_db
DB_USER=ironkey_user
DB_PASS=cambia_esto_por_una_contraseña_muy_segura

# -----------------------------------------------------------------------------
# JWT Secret — mínimo 64 caracteres
# Genera con: openssl rand -hex 64
# -----------------------------------------------------------------------------
JWT_SECRET=

# -----------------------------------------------------------------------------
# Pepper de cifrado — mínimo 32 caracteres
# Genera con: openssl rand -hex 32
# -----------------------------------------------------------------------------
ENCRYPTION_PEPPER=

# -----------------------------------------------------------------------------
# Recuperación de cuenta vía TOTP
# false (por defecto) = zero-knowledge puro sin recuperación
# true  = activa los endpoints de recovery (requiere 2FA configurado por usuario)
# -----------------------------------------------------------------------------
IRONKEY_RECOVERY_ENABLED=false

# -----------------------------------------------------------------------------
# CORS — origen(es) del frontend separados por coma
# Ejemplos:
#   https://tudominio.com
#   https://tudominio.com,https://app.tudominio.com
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://tudominio.com

# -----------------------------------------------------------------------------
# Dominio del servidor (usado en nginx.conf)
# -----------------------------------------------------------------------------
DOMAIN=tudominio.com
